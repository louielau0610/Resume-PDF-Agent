<!DOCTYPE html>
<html lang="{{ options.language }}">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>{{ page_title }}</title>
<style>{{ css }}</style>
</head>
<body>
<main class="app-shell">
<header class="top-bar">
  <span class="top-bar-brand">LLM Rewrite Review Console</span>
  <span class="top-bar-badge">Local Static Page</span>
</header>

<section class="hero-panel">
  <h1 class="hero-title">{{ page_title }}</h1>
  <p class="hero-subtitle">Review optional LLM rewrite candidates generated by M16. No candidates are applied automatically.</p>
</section>

{% if options.include_safety_notice %}
<section class="section-panel safety-notice">
  <div class="safety-notice-text">
    <strong>Safety Notice:</strong> {{ safety_notice }}
  </div>
</section>
{% endif %}

<section class="section-panel">
  <div class="section-panel-header"><h2 class="section-panel-title">Summary / 摘要</h2></div>
  <div class="summary-cards">
    <div class="summary-card"><span class="sc-label">Provider</span><span class="sc-value">{{ provider }}</span></div>
    <div class="summary-card"><span class="sc-label">Status</span><span class="sc-value {{ rewrite_status }}">{{ rewrite_status }}</span></div>
    <div class="summary-card"><span class="sc-label">Total Candidates</span><span class="sc-value">{{ candidate_count }}</span></div>
    <div class="summary-card"><span class="sc-label">Requiring Confirmation</span><span class="sc-value">{{ candidates_requiring_confirmation }}</span></div>
    <div class="summary-card"><span class="sc-label">Warnings</span><span class="sc-value">{{ warnings|length }}</span></div>
    <div class="summary-card"><span class="sc-label">Errors</span><span class="sc-value">{{ errors|length }}</span></div>
  </div>
  {% if warnings %}
  <div class="warnings-panel">
    <strong>Warnings:</strong>
    <ul>{% for w in warnings %}<li>{{ w }}</li>{% endfor %}</ul>
  </div>
  {% endif %}
</section>

{% if options.include_risk_filters %}
<section class="section-panel">
  <div class="section-panel-header"><h2 class="section-panel-title">Filter / 筛选</h2></div>
  <div class="filter-row">
    <button class="filter-btn active" onclick="filterCandidates('all')">All ({{ candidate_count }})</button>
    <button class="filter-btn" onclick="filterCandidates('requires_confirmation')">Needs Confirmation ({{ groups.requires_confirmation|length }})</button>
    <button class="filter-btn" onclick="filterCandidates('risk_flags')">Has Risk Flags ({{ groups.risk_flags|length }})</button>
    <button class="filter-btn" onclick="filterCandidates('validation_warnings')">Has Warnings ({{ groups.validation_warnings|length }})</button>
    <button class="filter-btn" onclick="filterCandidates('clean_candidates')">Clean ({{ groups.clean_candidates|length }})</button>
  </div>
</section>
{% endif %}

<section class="section-panel">
  <div class="section-panel-header"><h2 class="section-panel-title">Candidates / 候选</h2></div>
  <div id="candidates-container">
    {% for gname in ["requires_confirmation", "risk_flags", "validation_warnings", "clean_candidates"] %}
    {% for c in groups[gname] %}
    <div class="candidate-card" data-group="{{ gname }}" data-candidate-id="{{ c.candidate_id }}">
      <div class="candidate-header">
        <span class="candidate-id">#{{ c.candidate_id }}</span>
        {% if c.source_experience_id %}<span class="candidate-source">{{ c.source_experience_id }}</span>{% endif %}
        <span class="candidate-provider">{{ c.provider }} / {{ c.mode }}</span>
        <span class="candidate-status {{ c.status }}">{{ c.status }}</span>
        {% if c.needs_confirmation %}<span class="badge badge-confirm">Needs Confirmation</span>{% endif %}
        {% if c.risk_flags %}<span class="badge badge-risk">Risk: {{ c.risk_flags|join(', ') }}</span>{% endif %}
      </div>
      <div class="candidate-texts">
        <div class="text-block original">
          <div class="text-label">Original</div>
          <div class="text-content">{{ c.original_text }}</div>
        </div>
        <div class="text-block rewritten">
          <div class="text-label">LLM Rewrite</div>
          <div class="text-content">{{ c.rewritten_text }}</div>
        </div>
      </div>
      <div class="candidate-meta">
        <span>Evidence: <strong>{{ c.evidence_level }}</strong></span>
        <span>Metric: <strong>{{ c.metric_status }}</strong></span>
        {% if c.validation_warnings %}
        <div class="meta-warnings">Validation Warnings: {{ c.validation_warnings|join(', ') }}</div>
        {% endif %}
        {% if c.rationale %}
        <div class="meta-rationale">Rationale: {{ c.rationale }}</div>
        {% endif %}
      </div>
      {% if options.include_decision_controls %}
      <div class="decision-controls">
        {% for dopt in decision_options %}
        <label class="decision-radio"><input type="radio" name="decision-{{ c.candidate_id }}" value="{{ dopt.value }}" onchange="updateDecision('{{ c.candidate_id }}', '{{ dopt.value }}')"> {{ dopt.label }}</label>
        {% endfor %}
        <input type="text" class="decision-note" placeholder="Reviewer note (optional)" onchange="updateNote('{{ c.candidate_id }}', this.value)">
        <input type="text" class="decision-replacement" placeholder="Replacement text (optional)" onchange="updateReplacement('{{ c.candidate_id }}', this.value)">
      </div>
      {% endif %}
    </div>
    {% endfor %}
    {% endfor %}
  </div>
</section>

<section class="section-panel">
  <div class="section-panel-header"><h2 class="section-panel-title">Generated Decisions JSON / 生成的决策 JSON</h2></div>
  <textarea id="decisions-output" class="json-preview" rows="15" readonly placeholder="Select decisions above to generate JSON..."></textarea>
  <div class="decision-actions">
    {% if options.include_copy_buttons %}
    <button class="action-btn" onclick="copyDecisionsJSON()">Copy to Clipboard</button>
    {% endif %}
    {% if options.include_download_buttons %}
    <button class="action-btn" onclick="downloadDecisionsJSON()">Download llm_rewrite_review_decisions.json</button>
    {% endif %}
    <button class="action-btn action-btn-secondary" onclick="refreshDecisionsJSON()">Refresh JSON</button>
  </div>
</section>

{% if options.include_cli_instructions %}
<section class="section-panel">
  <div class="section-panel-header"><h2 class="section-panel-title">CLI Instructions / 命令行说明</h2></div>
  <ol>
    {% for inst in cli_instructions %}
    <li>{{ inst }}</li>
    {% endfor %}
  </ol>
</section>
{% endif %}

<footer class="footer-note">
  <p>Local static LLM review page. No data is submitted to any server.</p>
  <p>LLM candidates are suggestions only. Approve only text you can personally verify.</p>
  <p>This page does NOT call any real LLM API, does NOT apply candidates automatically, does NOT verify truth, and does NOT bypass M14 confirmation.</p>
  <p>It does NOT predict hiring probability or access internal screening standards.</p>
</footer>
</main>
<script>var CANDIDATES = {{ candidates_json }};</script>
<script>{{ js }}</script>
</body>
</html>
